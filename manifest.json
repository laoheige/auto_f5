{
  "manifest_version": 3,
  "name": "防过期自动刷新",
  "version": "1.1.0",
  "description": "定时自动刷新页面，防止网页会话过期，支持随机间隔防风控",
  "permissions": ["activeTab", "storage", "alarms"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
